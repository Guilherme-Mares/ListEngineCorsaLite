<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:ListEngineCorsaLite.Converters"
             x:Class="ListEngineCorsaLite.MainPage"
             Title="ListEngine Corsa Lite">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:FavoritoConverter x:Key="FavoritoConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid>
        <!-- Lista de Motores -->
        <CollectionView x:Name="MotoresCollection">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="10,5"
                           CornerRadius="10"
                           BackgroundColor="White"
                           Padding="15"
                           HasShadow="True">

                        <Grid ColumnDefinitions="Auto,*,Auto"
                              RowDefinitions="Auto,Auto">

                            <!-- Ícone -->
                            <Label Grid.Column="0" Grid.Row="0" Grid.RowSpan="2"
                                   Text="⚙️"
                                   FontSize="20"
                                   VerticalOptions="Center"
                                   Margin="0,0,10,0"/>

                            <!-- Informações -->
                            <VerticalStackLayout Grid.Column="1" Grid.Row="0">
                                <Label Text="{Binding Modelo}" 
                                       FontSize="16" 
                                       FontAttributes="Bold"/>
                                <Label Text="{Binding Codigo}" 
                                       FontSize="14"
                                       TextColor="#2196F3"/>
                            </VerticalStackLayout>

                            <!-- Botão Favorito -->
                            <Button Grid.Column="2" Grid.Row="0"
                                    Text="{Binding Favorito, Converter={StaticResource FavoritoConverter}}"
                                    BackgroundColor="Transparent"
                                    TextColor="#FF9800"
                                    FontSize="20"
                                    Clicked="OnFavoritoClicked"
                                    CommandParameter="{Binding .}"
                                    WidthRequest="40"
                                    HeightRequest="40"/>

                            <!-- Detalhes -->
                            <HorizontalStackLayout Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="1"
                                                   Margin="0,5">
                                <Frame BackgroundColor="#E8F5E8"
                                       CornerRadius="5"
                                       Padding="5,2">
                                    <Label Text="{Binding Potencia, StringFormat='{0} cv'}" 
                                           FontSize="12"
                                           FontAttributes="Bold"
                                           TextColor="#2E7D32"/>
                                </Frame>

                                <Frame BackgroundColor="#E3F2FD"
                                       CornerRadius="5"
                                       Padding="5,2"
                                       Margin="5,0">
                                    <Label Text="{Binding Cilindrada, StringFormat='{0} cc'}" 
                                           FontSize="12"
                                           FontAttributes="Bold"
                                           TextColor="#1565C0"/>
                                </Frame>

                                <Label Text="{Binding Periodo}" 
                                       FontSize="12"
                                       TextColor="#666"
                                       VerticalOptions="Center"
                                       Margin="10,0,0,0"/>
                            </HorizontalStackLayout>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        <!-- NO FINAL do Grid, antes do botão Adicionar, adicione: -->
        <Button x:Name="BtnEditar"
        Text="✏️"
        BackgroundColor="#FF9800"
        TextColor="White"
        CornerRadius="25"
        WidthRequest="50"
        HeightRequest="50"
        HorizontalOptions="End"
        VerticalOptions="End"
        Margin="0,0,80,20"
        Clicked="OnEditarClicked"
        IsVisible="False"/>
        <!-- Botão Adicionar -->
        <Button Text="➕"
                BackgroundColor="#2196F3"
                TextColor="White"
                CornerRadius="25"
                WidthRequest="50"
                HeightRequest="50"
                HorizontalOptions="End"
                VerticalOptions="End"
                Margin="0,0,20,20"
                Clicked="OnAdicionarClicked"/>

        <!-- Mensagem se não houver motores -->
        <VerticalStackLayout x:Name="EmptyView"
                             IsVisible="False"
                             HorizontalOptions="Center"
                             VerticalOptions="Center">
            <Label Text="🚗" 
                   FontSize="40"/>
            <Label Text="Nenhum motor cadastrado" 
                   FontSize="16"
                   TextColor="#666"
                   Margin="0,10"/>
            <Button Text="ADICIONAR PRIMEIRO MOTOR"
                    BackgroundColor="#4CAF50"
                    TextColor="White"
                    CornerRadius="10"
                    Clicked="OnAdicionarClicked"/>
        </VerticalStackLayout>
    </Grid>
</ContentPage>